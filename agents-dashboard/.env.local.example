# SHUI Agents Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# GitHub Personal Access Token (server-side only, never exposed to browser)
# Required scopes: repo read access only.
# Does NOT need: workflow, delete, admin, or production deploy scopes.
GITHUB_TOKEN=ghp_yourTokenHere

# Repository to monitor (org/repo format)
NEXT_PUBLIC_GITHUB_REPO=shui-official/shui-community

# Optional local LLM connection for agents
# Local dashboard only. Do NOT commit real secrets.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENTS_LLM_ENABLED=false
